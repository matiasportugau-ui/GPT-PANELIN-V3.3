# ==============================================================================
# Panelin Agno — Production Dockerfile
# ==============================================================================
# Arquitectura: FastAPI + Agno Agent + Wolf API legacy routes
# Target: Google Cloud Run (port 8080)

# Stage 1: Builder — instala dependencias Python
FROM python:3.11-slim AS builder

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    g++ \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt requirements-agno.txt* ./
COPY mcp/requirements.txt ./mcp-requirements.txt

RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt && \
    pip install --no-cache-dir -r mcp-requirements.txt && \
    pip install --no-cache-dir -r requirements-agno.txt 2>/dev/null || true

# Stage 2: Production
FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    libpq5 \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /usr/local/lib/python3.11/site-packages /usr/local/lib/python3.11/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin

# Código de la aplicación
COPY src/ /app/src/
COPY panelin_v4/ /app/panelin_v4/
COPY wolf_api/ /app/wolf_api/
COPY panelin_reports/ /app/panelin_reports/
COPY mcp/ /app/mcp/

# Knowledge Base (datos de productos)
COPY bromyros_pricing_master.json /app/
COPY bromyros_pricing_gpt_optimized.json /app/
COPY BMC_Base_Conocimiento_GPT-2.json /app/
COPY bom_rules.json /app/
COPY accessories_catalog.json /app/
COPY shopify_catalog_v1.json /app/
COPY corrections_log.json /app/
COPY bmc_logo.png /app/ 2>/dev/null || true

# Directorios de runtime
RUN mkdir -p /app/logs /app/panelin_reports/output /tmp/agno_sessions && \
    chmod -R 755 /app/logs /app/panelin_reports/output /tmp/agno_sessions

# Usuario no-root por seguridad
RUN useradd -m -u 1000 -s /bin/bash panelin && \
    chown -R panelin:panelin /app
USER panelin

# Cloud Run usa PORT=8080 por defecto
EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:${PORT:-8080}/v2/health || exit 1

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONPATH=/app \
    PORT=8080

CMD ["python", "-m", "uvicorn", "src.app:app", \
     "--host", "0.0.0.0", \
     "--port", "8080", \
     "--workers", "2", \
     "--log-level", "info"]
