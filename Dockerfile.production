# ==============================================================================
# Panelin AgentOS - Cloud Run Dockerfile
# ==============================================================================

FROM python:3.11-slim

LABEL maintainer="GPT-PANELIN Team"
LABEL description="Panelin AgentOS (Agno workflow + conversational agent + Wolf API compatibility)"

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install runtime dependencies
COPY requirements-agentos.txt /tmp/requirements-agentos.txt
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r /tmp/requirements-agentos.txt && \
    rm /tmp/requirements-agentos.txt

# Application code
COPY src/ /app/src/
COPY wolf_api/ /app/wolf_api/
COPY panelin_v4/ /app/panelin_v4/
COPY panelin_reports/ /app/panelin_reports/

# Domain data files (pricing, BOM rules, KB)
COPY bom_rules.json /app/
COPY accessories_catalog.json /app/
COPY bromyros_pricing_master.json /app/
COPY bromyros_pricing_gpt_optimized.json /app/
COPY BMC_Base_Conocimiento_GPT-2.json /app/
COPY wolf_api/catalog.json /app/catalog.json
COPY corrections_log.json /app/corrections_log.json

# Security: run as non-root user
RUN useradd -m -u 1000 -s /bin/bash panelin && \
    chown -R panelin:panelin /app

USER panelin

EXPOSE 8080

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PORT=8080 \
    PYTHONPATH=/app \
    CATALOG_PATH=/app/catalog.json

HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:8080/health || exit 1

CMD ["uvicorn", "src.app:app", "--host", "0.0.0.0", "--port", "8080"]
