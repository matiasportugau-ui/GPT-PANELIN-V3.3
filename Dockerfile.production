# ==============================================================================
# Panelin AgentOS Production Dockerfile
# ==============================================================================

FROM python:3.12-slim

LABEL maintainer="GPT-PANELIN Team"
LABEL description="Panelin AgentOS + deterministic v4 workflow"

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

COPY requirements-prod.txt /tmp/requirements-prod.txt
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r /tmp/requirements-prod.txt && \
    rm /tmp/requirements-prod.txt

# Application code
COPY src/ /app/src/
COPY panelin_v4/ /app/panelin_v4/
COPY panelin_reports/ /app/panelin_reports/

# Legacy catalog path expected by compatibility routes
RUN mkdir -p /app/wolf_api
COPY wolf_api/catalog.json /app/wolf_api/catalog.json

# Domain data
COPY bom_rules.json /app/
COPY accessories_catalog.json /app/
COPY bromyros_pricing_master.json /app/
COPY bromyros_pricing_gpt_optimized.json /app/
COPY BMC_Base_Conocimiento_GPT-2.json /app/
COPY bmc_logo.png /app/

RUN useradd -m -u 1000 -s /bin/bash panelin && \
    chown -R panelin:panelin /app

USER panelin

EXPOSE 8080

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONPATH=/app \
    PORT=8080 \
    CATALOG_PATH=/app/wolf_api/catalog.json

HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:8080/health || exit 1

CMD ["uvicorn", "src.app:app", "--host", "0.0.0.0", "--port", "8080"]
