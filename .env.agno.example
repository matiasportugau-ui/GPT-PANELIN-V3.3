# ==============================================================================
# Panelin v5.0 - Environment Variables (Agno Architecture)
# ==============================================================================
# Copy to .env and fill in values:  cp .env.agno.example .env

# ── Environment ──
ENVIRONMENT=development
DEBUG=true
PORT=8080
LOG_LEVEL=INFO

# ── Database (Cloud SQL PostgreSQL) ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=panelin
DB_USER=panelin
DB_PASSWORD=your_db_password
# For Cloud Run + Cloud SQL:
# CLOUD_SQL_CONNECTION_NAME=project:region:instance

# ── LLM Provider ──
LLM_PROVIDER=openai
LLM_MODEL_ID=gpt-4o
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...

# ── MCP Server ──
MCP_TRANSPORT=sse
MCP_URL=http://localhost:8000/sse
MCP_TIMEOUT=30

# ── Security ──
WOLF_API_KEY=your_secure_api_key
KB_WRITE_PASSWORD=your_secure_kb_password
JWT_SECRET=your_jwt_secret
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com

# ── Google Cloud Storage ──
KB_GCS_BUCKET=your-bucket-name

# ── Google Sheets CRM ──
SHEETS_SPREADSHEET_ID=your_spreadsheet_id
SHEETS_TAB_2026=Administrador de Cotizaciones 2026
SHEETS_TAB_ADMIN=Admin.
